<Project>

  <PropertyGroup>
    <!-- <IntermediateOutputPath>$(MSBuildThisFileDirectory)/build/bin/obj/$(TargetOS).$(TargetPlatform).$(Configuration)/$(AssemblyName)/</IntermediateOutputPath> -->
    <DefineConstants Condition="$(APPVEYOR) == 'True'">_APPVEYOR;$(DefineConstans)</DefineConstants>
    
    <!-- STAGE 3 CLEANUP -->
    <UseDjvuNetTaskFactory>true</UseDjvuNetTaskFactory>
    <GitTasksAssembly>$(MSBuildThisFileDirectory)Tools/DjvuNet/$(TargetFramework)/DjvuNet.Build.Tasks.dll</GitTasksAssembly>
  </PropertyGroup>

  <!-- New Tooling / Stage 2+ (With TaskFactory, New Namespace) -->
  <UsingTask TaskName="DjvuNet.Build.Tasks.BuildMajorVersion" Runtime="NET" Architecture="CurrentArchitecture" AssemblyFile="$(GitTasksAssembly)" TaskFactory="DjvuNet.Build.Tasks.DjvuNetBuildTaskFactory" />
  <UsingTask TaskName="DjvuNet.Build.Tasks.GetLastCommit" Runtime="NET" Architecture="CurrentArchitecture" AssemblyFile="$(GitTasksAssembly)" TaskFactory="DjvuNet.Build.Tasks.DjvuNetBuildTaskFactory" />
  <UsingTask TaskName="DjvuNet.Build.Tasks.GetDateTime" Runtime="NET" Architecture="CurrentArchitecture" AssemblyFile="$(GitTasksAssembly)" TaskFactory="DjvuNet.Build.Tasks.DjvuNetBuildTaskFactory" />
  <UsingTask TaskName="MSBuild.Community.Tasks.FileUpdate" Runtime="NET" Architecture="CurrentArchitecture" AssemblyFile="$(GitTasksAssembly)" TaskFactory="DjvuNet.Build.Tasks.DjvuNetBuildTaskFactory" />

  <Target Name="CalculateVersion" BeforeTargets="InjectVersion">
    <ReadLinesFromFile File="$(MSBuildThisFileDirectory)library.version">
      <Output TaskParameter="Lines" PropertyName="LibraryVersion" />
    </ReadLinesFromFile>

    <GetLastCommit Condition="Exists('$(MSBuildThisFileDirectory).git')" RepoRoot="$(MSBuildThisFileDirectory)">
      <Output TaskParameter="CommitHash" PropertyName="CommitVersion" />
      <Output TaskParameter="BranchName" PropertyName="BuildBranch" />
    </GetLastCommit>

    <PropertyGroup>
      <CommitVersion Condition="'$(CommitVersion)' == ''">N/A</CommitVersion>
      <BuildBranch Condition="'$(BuildBranch)' == ''">N/A</BuildBranch>
    </PropertyGroup>

    <GetDateTime Format="yyyy-MM-ddTHH:mm:ssZ">
      <Output TaskParameter="Year" PropertyName="BYear" />
      <Output TaskParameter="Month" PropertyName="BMonth" />
      <Output TaskParameter="Day" PropertyName="BDay" />
      <Output TaskParameter="Hour" PropertyName="BHour" />
      <Output TaskParameter="Minute" PropertyName="BMinute" />
      <Output TaskParameter="Second" PropertyName="BSecond" />
    </GetDateTime>

    <BuildMajorVersion MajorMinorVersion="$(LibraryVersion)" RepoRoot="$(MSBuildThisFileDirectory)">
      <Output TaskParameter="Version" PropertyName="DjvuAssemblyVersion" />
      <Output TaskParameter="FullVersion" PropertyName="InformationalVersion" />
    </BuildMajorVersion>
  </Target>

  <Target Name="UpdateVersionCache" BeforeTargets="InjectVersion" DependsOnTargets="CalculateVersion">
    <PropertyGroup>
      <VersionCacheFile>$(MSBuildThisFileDirectory).build.version</VersionCacheFile>
      <CalculatedCacheContent>$(DjvuAssemblyVersion);$(InformationalVersion);$(BYear);$(BuildBranch);$(CommitVersion)</CalculatedCacheContent>
      <ExistingCacheContent></ExistingCacheContent>
    </PropertyGroup>

    <ReadLinesFromFile File="$(VersionCacheFile)" Condition="Exists('$(VersionCacheFile)')">
      <Output TaskParameter="Lines" PropertyName="ExistingCacheContent" />
    </ReadLinesFromFile>

    <Message Importance="High" Text="  ================= VERSION CACHE ==================" />
    <Message Importance="High" Text="  = Existing:   [$(ExistingCacheContent)]" />
    <Message Importance="High" Text="  = Calculated: [$(CalculatedCacheContent)]" />
    <Message Importance="High" Text="  ==================================================" />

    <ItemGroup>
      <VersionCacheLines Include="$(DjvuAssemblyVersion)" />
      <VersionCacheLines Include="$(InformationalVersion)" />
      <VersionCacheLines Include="$(BYear)" />
      <VersionCacheLines Include="$(BuildBranch)" />
      <VersionCacheLines Include="$(CommitVersion)" />
    </ItemGroup>

    <!-- Only write if the file doesn't exist OR the concatenated content differs -->
    <!-- File participates in the incremental build logic preventing unnecessary writes and build lock race conditions -->
    <WriteLinesToFile File="$(VersionCacheFile)" Lines="@(VersionCacheLines)" Overwrite="true"
                      Condition="!Exists('$(VersionCacheFile)') Or '$(ExistingCacheContent)' != '$(CalculatedCacheContent)'" />
  </Target>

  <Target Name="InjectVersion" BeforeTargets="CoreCompile" DependsOnTargets="UpdateVersionCache"
          Inputs="$(MSBuildThisFileDirectory).build.version;$(ProjectDir)Properties\AssemblyInfo.Template.cs;$(MSBuildThisFileDirectory)Templates\AssemblyInfoCommon.Template.cs"
          Outputs="$(ProjectDir)Properties\AssemblyInfo.$(TargetFramework).cs;$(ProjectDir)Properties\AssemblyInfoCommon.$(TargetFramework).cs">

    <Error Condition="'$(TargetFramework)' == 'net472'" Text="The net472 target framework is deprecated and no longer supported in this build pipeline." />

    <PropertyGroup>
      <UtilRepoRootUpdate>$(ProjectName.EndsWith(`.Tests`))</UtilRepoRootUpdate>
      <UtilTestFile>$(RepoRootDir)DjvuNet.Shared.Tests/UtilRoot*.cs</UtilTestFile>
    </PropertyGroup>

    <Message Importance="High"
             Text="Building [$(TargetName)] target framework: [$(TargetFramework)], assembly version: [$(DjvuAssemblyVersion)], file version: [$(InformationalVersion)], configuration: [$(Configuration)], platform [$(Platform)], branch: [$(BuildBranch)] commit: [$(CommitVersion)]"/>

    <Copy SourceFiles="$(ProjectDir)Properties\AssemblyInfo.Template.cs"
          DestinationFiles="$(ProjectDir)Properties\AssemblyInfo.$(TargetFramework).cs"/>
    <Copy SourceFiles="$(MSBuildThisFileDirectory)Templates\AssemblyInfoCommon.Template.cs"
          DestinationFiles="$(ProjectDir)Properties\AssemblyInfoCommon.$(TargetFramework).cs"/>

    <Copy SourceFiles="$(MSBuildThisFileDirectory)Templates\UtilRoot.Template.cs" Condition="$(UtilRepoRootUpdate) == true"
          DestinationFiles="$(RepoRootDir)DjvuNet.Shared.Tests/UtilRoot.cs"/>

    <ItemGroup>
      <WriteFiles Include='$(ProjectDir)Properties\AssemblyInfo.$(TargetFramework).cs' />
      <WriteFiles Include='$(ProjectDir)Properties\AssemblyInfoCommon.$(TargetFramework).cs' />
    </ItemGroup>

    <ItemGroup>
      <UtilFiles Include='$(UtilTestFile)' Condition="$(UtilRepoRootUpdate) == true" />
    </ItemGroup>

    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_VERSION__" ReplacementText="$(DjvuAssemblyVersion)"/>
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_FULL_VERSION__" ReplacementText="$(InformationalVersion)"/>
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_CONFIGURATION__" ReplacementText="$(Configuration)"/>
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_PLATFORM__" ReplacementText="$(Platform)"/>
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_BYEAR__" ReplacementText="$(BYear)" />
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_REPO_BRANCH__" ReplacementText="$(BuildBranch)" />
    <FileUpdate Files="@(WriteFiles)" Regex="__LIBRARY_COMMIT__" ReplacementText="$(CommitVersion)"/>

    <FileUpdate Files="@(WriteFiles)" Regex="// TEMPLATE:.+"
    ReplacementText="// THIS FILE IS AUTOMATICALLY GENERATED DURING BUILD!&#10;// Apply any changes intended to appear in AssemblyInso.cs to 'AssemblyInfo.Template.cs' template,&#10;// in the case of AssemblyInfoCommon.cs file apply changes to AssemblyInfoCommon.Template.cs file in root folder instead."/>

    <FileUpdate Condition="$(UtilRepoRootUpdate) == true" Files="@(UtilFiles)" Regex="@@@DJVUNET_ROOT@@@" ReplacementText="$(MSBuildThisFileDirectory)"/>

    <FileUpdate Files="@(UtilFiles)" Regex="// TEMPLATE:.+" Condition="$(UtilRepoRootUpdate) == true"
    ReplacementText="// THIS FILE IS AUTOMATICALLY GENERATED DURING BUILD!&#10;// Apply any changes intended to appear in UtilRoot.cs to 'UtilRoot.Template.cs' template, instead."/>

  </Target>

  <Target Name="InjectPackageVersion" BeforeTargets="Pack" DependsOnTargets="CalculateVersion">
    <PropertyGroup>
      <PackageVersion>$(InformationalVersion)</PackageVersion>
    </PropertyGroup>
    <Message Importance="High"
             Text="Packaging [$(PackageId)] target frameworks: [@(_TargetFrameworks)], assembly version: [$(DjvuAssemblyVersion)], version: [$(InformationalVersion)], configuration: [$(Configuration)], platform [$(Platform)], commit: [$(CommitVersion)]"/>
  </Target>

  <Target Name="PrepareCopyXUnitTestProduct"
      AfterTargets="Build"
      BeforeTargets="CopyXUnitTestProduct">

    <PropertyGroup>
      <CopyPublishXUnitPackages Condition="'$(IsDjvuNetTestProject)' == 'True'">true</CopyPublishXUnitPackages>
    </PropertyGroup>

    <ItemGroup>
      <PackageReferenceFiles
        Condition="%(PackageReference.CopyToOutputDirectory) != ''"
        Include="$(NugetPackageRoot)\%(PackageReference.Identity)\%(PackageReference.Version)\%(PackageReference.CopyToOutputDirectory)" />
    </ItemGroup>

    <Message Condition="'$(CopyPublishXUnitPackages)' == 'true'" Text="Target CopyXUnitTestProduct CopyPublishXUnitPackages: %(PackageReferenceFiles.Identity)" Importance="High" />
  </Target>

  <Target
    Name="CopyXUnitTestProduct"
    AfterTargets="PrepareCopyXUnitTestProduct"
    Condition="'$(CopyPublishXUnitPackages)' == 'true'">

    <Copy SourceFiles="@(PackageReferenceFiles)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" ContinueOnError="false" />

  </Target>

</Project>
